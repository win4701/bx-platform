.\[\&_div\]\:snap-end div { scroll-snap-align: end; }

.\[\&_div\]\:truncate div { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.\[\&_svg\]\:-mt-1 svg { margin-top: -0.25rem; }

