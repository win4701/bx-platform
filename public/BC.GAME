.button { display: flex; align-items: center; justify-content: center; height: 3rem; padding-left: 0.5rem; padding-right: 0.5rem; cursor: pointer; border-radius: var(--radius-md); user-select: none; }

.button-xs { height: 1.5rem; border-radius: var(--radius-md); }

