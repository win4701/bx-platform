{
  "name": "bx-backend",
  "version": "1.0.0",
  "description": "BX Network Backend Infrastructure",
  "main": "server.js",
  "private": true,
  "type": "commonjs",

  "engines": {
    "node": ">=18"
  },

  "scripts": {

    "start":
      "node server.js",

    "dev":
      "nodemon server.js",

    "prod":
      "NODE_ENV=production node server.js",

    "check":
      "node -v && npm -v",

    "health":
      "curl http://localhost:3000/health",

    "lint":
      "echo lint ready",

    "clean":
      "rm -rf node_modules package-lock.json",

    "reinstall":
      "npm run clean && npm install"

  },

  "dependencies": {

    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "uuid": "^9.0.1",
    "validator": "^13.12.0",
    "ws": "^8.17.1"

  },

  "devDependencies": {

    "nodemon": "^3.1.0"

  },

  "keywords": [

    "bxs",
    "blockchain",
    "crypto",
    "exchange",
    "wallet",
    "mining",
    "websocket",
    "nodejs",
    "express",
    "postgresql"

  ],

  "author": "BXS Network",

  "license": "MIT"
}
